*

# Keep the repo-level ignore file
!/.gitignore
!/.gitattributes
!/LICENSE
!/README.md

# Publish only the flattened CPU source tree
!/src/
!/src/**/
!/src/*.py
!/src/*.csv
!/src/**/*.py
!/src/**/*.csv
!/src/V_ion/splineData.mat

# Ignore generated Python artifacts anywhere
**/__pycache__/
**/*.py[cod]

# Local-only folders
/.cuda-shim/
/.cupy-cache/
/.mplconfig/
/.tmp/
/.venv/
/.venv312/
/parsec_python-cpu/
/parsec_python-gpu/
/samples/
!/samples/
!/samples/**
/.DS_Store
