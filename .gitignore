*

# Keep the repo-level ignore file
!/.gitignore
!/.gitattributes
!/LICENSE
!/README.md

# Publish only the flattened CPU source tree
!/src/
!/src/**/
!/src/*.py
!/src/*.csv
!/src/**/*.py
!/src/**/*.csv

# Ignore generated Python artifacts anywhere
**/__pycache__/
**/*.py[cod]

# Local-only folders
/.cuda-shim/
/.cupy-cache/
/.mplconfig/
/.tmp/
/.venv/
/.venv312/
/parsec_python-cpu/
/parsec_python-gpu/
/samples/
/.DS_Store
